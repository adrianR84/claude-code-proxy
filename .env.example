# PROVIDER API KEYS
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Custom provider
CUSTOM_MODEL=qwen/qwen3-235b-a22b
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# Routing
# CUSTOM_MODEL overrides ALL models. Comment it to use PREFERRED_PROVIDER routing with haiku/sonnet/opus → BIG/SMALL mapping.
PREFERRED_PROVIDER=openai
OPENAI_BASE_URL=
BIG_MODEL=gpt-4.1
SMALL_MODEL=gpt-4.1-mini

